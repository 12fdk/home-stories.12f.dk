---
import { getCollection } from "astro:content"
import HomePage from "@modules/home"
import Layout from "Layout.astro"
import defaultTemplateConfig from "utils/config"
import { fetchAppStoreData, fallbackAppStoreData, toAppStoreMetadata } from "utils/appStoreData"
import { readingTime } from "utils/readingTime"
import { NON_DEFAULT_LOCALES } from "../../i18n/locales"
import { getLocalizedConfig } from "../../i18n/getConfig"
import type { TemplateConfig } from "utils/configType"

// One page per non-default locale: /de/, /fr/, /ja/, … English lives at the
// root (src/pages/index.astro). App Store data is fetched once here and handed
// to every locale via props, so the build makes a single network call.
export async function getStaticPaths() {
  const appStoreData = (await fetchAppStoreData()) ?? fallbackAppStoreData;
  const appStore = toAppStoreMetadata(appStoreData);
  // Self-hosted build-time copy of the App Store icon (see app-icon-512.jpg.ts). #74
  const logo = "/app-icon-512.jpg";

  const posts = (await getCollection("blog", ({ data }) => !data.draft))
    .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
    .slice(0, 3)
    .map((post) => ({
      slug: post.slug,
      title: post.data.title,
      description: post.data.description,
      date: post.data.publishDate.toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
      }),
      minutes: readingTime(post.body).minutes,
    }));

  return NON_DEFAULT_LOCALES.map((l) => ({
    params: { lang: l.code },
    props: { appStore, logo, posts },
  }));
}

const { lang } = Astro.params;
const { appStore, logo, posts } = Astro.props;

const baseConfig: TemplateConfig = {
  ...defaultTemplateConfig,
  logo,
  appStore,
};

const config = getLocalizedConfig(baseConfig, lang!);
---

<Layout {...config}>
  <HomePage client:load config={config} posts={posts} />
</Layout>
